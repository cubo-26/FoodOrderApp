<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivManageThumb"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:background="@drawable/rounded_image"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="12dp">

            <TextView
                android:id="@+id/tvManageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvManageCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/primary_orange"
                    android:background="@drawable/chip_category_small"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"/>

                <TextView
                    android:id="@+id/tvManageStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvManagePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary_orange"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnEditFood"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_edit"
                android:padding="8dp"
                android:background="@drawable/btn_edit_bg"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/primary_orange"/>

            <ImageView
                android:id="@+id/btnDeleteFood"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_delete"
                android:padding="8dp"
                android:background="@drawable/btn_delete_bg"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/error_red"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
